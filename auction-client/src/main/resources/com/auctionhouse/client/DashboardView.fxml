<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.TilePane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.auctionhouse.client.controller.DashboardController"
            style="-fx-background-color: #221f1d;">

    <top>
        <VBox spacing="18"
              style="-fx-background-color: #34302c; -fx-padding: 18 24 18 24;
                     -fx-border-color: #4d4640; -fx-border-width: 0 0 1 0;">

            <HBox alignment="CENTER_LEFT" spacing="14">
                <Label text="Auction System"
                       style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #f5f3ef;"/>

                <Region HBox.hgrow="ALWAYS"/>

                <Button fx:id="sellerBtn" text="Manage Auctions" onAction="#goToSeller"
                        style="-fx-background-color: #d8f4ec; -fx-text-fill: #2b7462;
                               -fx-font-size: 12px; -fx-font-weight: bold;
                               -fx-background-radius: 999; -fx-padding: 8 14; -fx-cursor: hand;"/>
                <Button text="Refresh" onAction="#refreshDashboard"
                        style="-fx-background-color: transparent; -fx-text-fill: #ded9d2;
                               -fx-font-size: 12px; -fx-font-weight: bold;
                               -fx-border-color: #6b655f; -fx-border-width: 1;
                               -fx-border-radius: 999; -fx-background-radius: 999;
                               -fx-padding: 8 14; -fx-cursor: hand;"/>
                <Button fx:id="logoutButton" text="Logout" onAction="#handleLogout"
                        style="-fx-background-color: transparent; -fx-text-fill: #f0b4b4;
                               -fx-font-size: 12px; -fx-font-weight: bold;
                               -fx-border-color: #8f6a6a; -fx-border-width: 1;
                               -fx-border-radius: 999; -fx-background-radius: 999;
                               -fx-padding: 8 14; -fx-cursor: hand;"/>

                <VBox alignment="CENTER_RIGHT" spacing="2">
                    <Label fx:id="currentUserLabel" text="Hello, User"
                           style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #f5f3ef;"/>
                    <Label fx:id="roleBadgeLabel" text="Bidder"
                           style="-fx-font-size: 11px; -fx-text-fill: #d2cbc3;"/>
                </VBox>

                <StackPane minWidth="40" minHeight="40" maxWidth="40" maxHeight="40"
                           onMouseClicked="#openAccountView"
                           style="-fx-background-color: #ece7ff; -fx-background-radius: 999; -fx-cursor: hand;">
                    <Label fx:id="avatarLabel" text="U"
                           style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #5d4ccf;"/>
                </StackPane>
            </HBox>

            <HBox spacing="10">
                <Button fx:id="allFilterButton" text="All" onAction="#showAllAuctions"
                        style="-fx-background-radius: 999; -fx-padding: 8 16;"/>
                <Button fx:id="runningFilterButton" text="Running" onAction="#showRunningAuctions"
                        style="-fx-background-radius: 999; -fx-padding: 8 16;"/>
                <Button fx:id="openFilterButton" text="Open" onAction="#showOpenAuctions"
                        style="-fx-background-radius: 999; -fx-padding: 8 16;"/>
                <Button fx:id="finishedFilterButton" text="Ended" onAction="#showFinishedAuctions"
                        style="-fx-background-radius: 999; -fx-padding: 8 16;"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <VBox spacing="14" style="-fx-padding: 18 24 24 24; -fx-background-color: #221f1d;">
            <HBox alignment="CENTER_LEFT" spacing="12">
                <VBox spacing="4">
                    <Label text="Featured Auctions"
                           style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #f5f3ef;"/>
                    <Label fx:id="summaryLabel" text="0 auctions shown"
                           style="-fx-font-size: 12px; -fx-text-fill: #b9b4ad;"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="actionStatusLabel" text=""
                       style="-fx-font-size: 12px; -fx-text-fill: #e6ddd3;"/>
            </HBox>

            <ScrollPane fitToWidth="true"
                        VBox.vgrow="ALWAYS"
                        style="-fx-background: transparent; -fx-background-color: transparent;
                               -fx-border-color: transparent;">
                <content>
                    <TilePane fx:id="auctionTilePane"
                              prefColumns="2"
                              prefTileWidth="360"
                              hgap="16"
                              vgap="18"
                              style="-fx-padding: 4 0 12 0;"/>
                </content>
            </ScrollPane>
        </VBox>
    </center>
</BorderPane>
